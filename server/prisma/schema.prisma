generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Worker {
  id               Int          @id @default(autoincrement())
  workerId         String       @unique @map("worker_id")
  name             String
  pinHash          String       @map("pin_hash")
  lineData         String?      @map("line_data")
  category         String?      @map("category")
  experience       String?      @map("experience")
  requiresPinReset Boolean      @default(true) @map("requires_pin_reset")
  isActive         Boolean      @default(true) @map("is_active")
  createdAt        DateTime     @default(now()) @map("created_at")
  attendances      Attendance[]
  subscriptions    PushSubscription[]

  @@map("workers")
}

model Manager {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  pinHash   String   @map("pin_hash")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("managers")
}

model SystemSettings {
  id                  Int     @id @default(autoincrement())
  masterData          String  @default("{}") @map("master_data")
  notificationTime    String  @map("notification_time")
  notificationEnabled Boolean @default(true) @map("notification_enabled")
  callAlertEnabled    Boolean @default(false) @map("call_alert_enabled")
  callAlertTime       String? @map("call_alert_time")
  editDeadlineEnabled Boolean @default(false) @map("edit_deadline_enabled")
  editDeadlineTime    String? @map("edit_deadline_time")
  vapidPublic         String? @map("vapid_public")
  vapidPrivate        String? @map("vapid_private")

  @@map("system_settings")
}

model Attendance {
  id         Int      @id @default(autoincrement())
  workerId   Int      @map("worker_id")
  lineData   String   @default("Unassigned") @map("line_data")
  category   String   @default("Unassigned")
  experience String   @default("Unassigned")
  isPresent  Boolean  @default(true) @map("is_present")
  date       String   // "YYYY-MM-DD" string
  timestamp  DateTime @default(now())
  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, date])
  @@map("attendances")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  workerId  Int
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
}
