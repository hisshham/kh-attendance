# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/workcomm?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this"
REFRESH_SECRET="your-super-secret-refresh-key-change-this"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# Firebase Cloud Messaging (paste from Firebase Console → Project Settings → Service Accounts)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Google Drive (Service Account for Excel uploads)
GOOGLE_DRIVE_FOLDER_ID=""
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY=""

# Manager default credentials (used in seed only)
MANAGER_DEFAULT_PIN="123456"
